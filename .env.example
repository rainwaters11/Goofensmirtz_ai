# ===========================
# Pet POV AI — Environment Variables
# ===========================
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to version control.

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Cloudinary ---
# Either set CLOUDINARY_URL (legacy SDK format) or the three named vars below.
# Named vars are preferred for new code.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- Google Gemini ---
GEMINI_API_KEY=your-gemini-key

# --- ElevenLabs TTS ---
# Primary TTS provider. Use ELEVENLABS_API_KEY in new code.
ELEVENLABS_API_KEY=your-elevenlabs-key

# --- TTS (generic — legacy; prefer named provider key above) ---
TTS_API_KEY=your-tts-key
TTS_PROVIDER=elevenlabs   # elevenlabs | google | openai

# --- FFmpeg ---
# Optional: explicit path to ffmpeg binary. Defaults to $PATH if unset.
FFMPEG_PATH=/usr/local/bin/ffmpeg

# --- Redis (for worker queue) ---
REDIS_URL=redis://localhost:6379

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:4000
PORT=4000
WORKER_CONCURRENCY=4

# --- Manus (external workflow agent) ---
MANUS_API_KEY=sk-...

# --- Modal.com (Video Rendering) ---
USE_MODAL_RENDER=false
MODAL_TOKEN_ID=ak-...
MODAL_TOKEN_SECRET=as-...
